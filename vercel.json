{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/google853ead28f29bf53f.html",
      "dest": "/google853ead28f29bf53f.html"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}